# -----------------------------------------------
#  QR Attendance System – Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# -----------------------------------------------

APP_URL=http://localhost/attendance_system/public
DB_HOST=localhost
DB_USER=root
DB_PASS=        ← leave empty, XAMPP default has no password
DB_NAME=qr_attendance

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qr_attendance
DB_USER=root
DB_PASS=

# Session
SESSION_LIFETIME=7200        # seconds (2 hours)
SESSION_NAME=qr_att_session

# QR Code
QR_EXPIRY_MINUTES=15         # how long a session QR stays valid
QR_SECRET=change_this_secret_key_for_signing

# Timezone
APP_TIMEZONE=Africa/Blantyre


